{% extends 'base.html.twig' %}

{% block title %}Inscription - {{ site_name }}{% endblock %}
{% block navbar %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
<div class="register-wrapper">
    <div class="register-card">
        <h1 class="register-title">Inscription</h1>

        {{ form_start(registrationForm) }}
            <div class="mb-4">
                {{ form_widget(registrationForm.pseudo) }}
                {{ form_errors(registrationForm.pseudo) }}
            </div>
            <div class="mb-4">
                {{ form_widget(registrationForm.email) }}
                {{ form_errors(registrationForm.email) }}
            </div>
            <div class="mb-4">
                {{ form_widget(registrationForm.plainPassword) }}
                {{ form_errors(registrationForm.plainPassword) }}
            </div>
            <div class="text-center mt-4">
                <button type="submit" class="btn btn-register">S'inscrire</button>
            </div>
            <div class="text-center mt-4">
                <a href="{{ path('app_login') }}" class="register-link">Déjà un compte ? Se connecter</a>
            </div>
        {{ form_end(registrationForm) }}
    </div>
</div>
{% endblock %}
