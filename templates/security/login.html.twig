{% extends 'base.html.twig' %}

{% block title %}Connexion - {{ site_name }}{% endblock %}
{% block navbar %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
<div class="login-wrapper">
    <div class="login-card">
        <h1 class="login-title">Connexion</h1>

        {% if error %}
            <div class="alert alert-danger text-center">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post">
            <div class="mb-4">
                <input type="email" name="_username" class="form-control custom-input" placeholder="E-mail" value="{{ last_username }}" required autofocus>
            </div>
            <div class="mb-4">
                <input type="password" name="_password" class="form-control custom-input" placeholder="Password" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-login">Connexion</button>
            </div>
            <div class="text-center mt-4">
                <a href="{{ path('app_register') }}" class="login-link">Pas encore de compte ? S'inscrire</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
