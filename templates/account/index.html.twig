{% extends 'base.html.twig' %}

{% block title %}Compte - {{ site_name }}{% endblock %}

{% block navbar %}
<nav class="navbar navbar-expand-lg" style="background-color:#6366F1;">
    <div class="container">
        <a class="navbar-brand text-white fw-bold" href="{{ path('app_home') }}">I.sAunny</a>
        <div class="d-flex align-items-center">
            <span class="text-white me-3">{{ app.user.pseudo }}</span>
            <a href="{{ path('app_home') }}" class="btn btn-light btn-sm me-2 log-btn">Blog</a>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin_dashboard') }}" class="btn btn-warning btn-sm me-2 log-btn">Admin</a>
            {% endif %}
            <a href="{{ path('app_logout') }}" class="btn btn-danger btn-sm log-btn2">Déconnexion</a>
        </div>
    </div>
</nav>
{% endblock %}

{% block body %}
<div class="container my-5">
    <h1 class="text-center mb-4">Gestion du compte</h1>
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card shadow" style="background-color:#6366F1; color:#F8FAFC;">
                <div class="card-body p-4">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_label(form.pseudo) }}
                            {{ form_widget(form.pseudo) }}
                            {{ form_errors(form.pseudo) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.email) }}
                            {{ form_widget(form.email) }}
                            {{ form_errors(form.email) }}
                        </div>
                        <div class="text-center mt-4">
                            <button type="submit" class="btn btn-primary" style="background-color:#111827; border:none; border-radius:999px; padding:10px 34px;">Mettre à jour</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
