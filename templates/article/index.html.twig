{% extends 'base.html.twig' %}

{% block title %}Articles - {{ site_name }}{% endblock %}

{% block body %}
<main>
    <section>
        <img src="{{ asset('img/articles.png') }}" alt="Bannière" class="img-fluid w-100 lg-100 hero-img" style="padding:30px; background-color:#0F172A;">
    </section>
    <div class="container my-5">
        <div class="row g-4">
            {% for article in articles %}
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow" style="background-color:#1E293B; color:#F8FAFC;">
                        <img src="{{ asset('img/' ~ article.image) }}" class="card-img-top" alt="{{ article.titre }}" style="height:220px; object-fit:cover;">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">{{ article.titre }}</h5>
                            <p class="mb-2" style="color:#CBD5E1; font-size:0.9rem;">
                                {{ article.categorie.nom }} ·
                                {{ article.date ? article.date|date('d/m/Y') : '' }}
                            </p>
                            <p class="card-text" style="color:#E2E8F0;">{{ article.description|u.truncate(120, '...') }}</p>
                            <div class="mt-auto">
                                <a href="{{ path('app_article_show', {id: article.id}) }}" class="btn btn-primary" style="background-color:#6366F1;">Lire l'article</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</main>
{% endblock %}
