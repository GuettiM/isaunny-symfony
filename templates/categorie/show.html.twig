{% extends 'base.html.twig' %}

{% block title %}{{ categorie.nom }} - {{ site_name }}{% endblock %}

{% block body %}
<div class="container my-5">
    <h1 class="text-center mb-5">Catégorie : {{ categorie.nom }}</h1>

    <div class="row g-4">
        {% if articles|length > 0 %}
            {% for article in articles %}
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow" style="background-color:#1E293B; color:#F8FAFC;">
                        <img src="{{ asset('img/' ~ article.image) }}" class="card-img-top" style="height:220px; object-fit:cover;" alt="{{ article.titre }}">
                        <div class="card-body d-flex flex-column">
                            <h5>{{ article.titre }}</h5>
                            <p style="color:#CBD5E1;">{{ article.date ? article.date|date('d/m/Y') : '' }}</p>
                            <div class="mt-auto">
                                <a href="{{ path('app_article_show', {id: article.id}) }}" class="btn btn-primary" style="background-color:#6366F1;">Lire</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <p class="text-center">Aucun article dans cette catégorie.</p>
        {% endif %}
    </div>
</div>
{% endblock %}
