{% extends 'base.html.twig' %}

{% block title %}Catégories - {{ site_name }}{% endblock %}

{% block body %}
<main>
    <section>
        <img src="{{ asset('img/categorie.png') }}" alt="Bannière" class="img-fluid w-100 lg-100 hero-img" style="padding:20px; background-color:#0F172A;">
    </section>
    <div class="container my-5">
        <div class="row g-4 justify-content-center">
            {% for categorie in categories %}
                <div class="col-12 col-sm-6 col-lg-3">
                    <a href="{{ path('app_categorie_show', {id: categorie.id}) }}" class="text-decoration-none">
                        <div class="card h-100 text-center shadow" style="background-color:#1E293B; color:#F8FAFC;">
                            <div class="card-body d-flex flex-column justify-content-center">
                                <h4>{{ categorie.nom }}</h4>
                            </div>
                        </div>
                    </a>
                </div>
            {% endfor %}
        </div>
    </div>
</main>
{% endblock %}
